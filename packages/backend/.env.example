# DevOps Configuration
DEVOPS_REDIS_HOST=localhost
DEVOPS_REDIS_PORT=6379

# Build Configuration
BUILD_TIMEOUT=1800000
BUILD_PARALLEL_JOBS=4
BUILD_CACHE_DIR=/tmp/build-cache

# Docker Configuration
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your-username
DOCKER_PASSWORD=your-password
DOCKER_NAMESPACE=your-namespace

# Kubernetes Configuration
K8S_API_URL=https://kubernetes.cluster
K8S_TOKEN=your-token
K8S_NAMESPACE=production

# SSH/VPS Configuration
SSH_KEY_PATH=/etc/keys/deploy-key
SSH_USER=deploy
SSH_TIMEOUT=30000

# Environment Variables Encryption
ENCRYPTION_KEY=your-secure-key-here

# Deployment Configuration
DEPLOYMENT_HEALTH_CHECK_INTERVAL=300000
DEPLOYMENT_TIMEOUT=3600000
AUTO_ROLLBACK_ON_FAILURE=true
ROLLBACK_WAIT_TIME=300000

# Artifact Storage
ARTIFACT_STORAGE_TYPE=local
ARTIFACT_STORAGE_PATH=/var/artifacts
ARTIFACT_RETENTION_DAYS=30

# Monitoring
MONITORING_INTERVAL=60000
UPTIME_CHECK_INTERVAL=300000

# Logging
DEPLOYMENT_LOG_RETENTION_DAYS=90
BUILD_LOG_RETENTION_DAYS=60

# WebSocket
WS_URL=ws://localhost:3001
WS_RECONNECT_INTERVAL=5000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
FRONTEND_URL=http://localhost:3000